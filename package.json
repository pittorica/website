{
  "name": "@pittorica/website",
  "version": "0.0.0",
  "private": true,
  "description": "Pittorica docs website",
  "keywords": [
    "pittorica",
    "website",
    "documentation",
    "docs"
  ],
  "bugs": {
    "url": "https://github.com/pittorica/website/issues"
  },
  "repository": {
