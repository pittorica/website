    "@react-router/serve": "^7.13.1",
    "@tabler/icons-react": "^3.40.0",
    "isbot": "^5.1.36",
    "motion": "^12.36.0",
    "pittorica": "^0.28.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@cspell/cspell-types": "^9.7.0",
