    "url": "git+https://github.com/pittorica/website.git"
  },
  "license": "MIT",
  "author": "Davide Di Criscito",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "fmt": "pnpm dlx prettier --ignore-unknown --write .",
    "lint": "pnpm dlx eslint --no-warn-ignored --fix .",
    "lint:fmt": "pnpm run lint && pnpm run fmt",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "commitlint": {
    "extends": [
      "spellbookx"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
